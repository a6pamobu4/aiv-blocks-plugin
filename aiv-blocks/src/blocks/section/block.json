{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "aiv/section",
	"version": "0.1.0",
	"title": "AIV Section",
	"category": "aiv-blocks",
	"description": "A semantic section wrapper for page composition.",
	"textdomain": "aiv-blocks",
	"attributes": {
		"variant": { "type": "string", "default": "default" },
		"spacing": { "type": "string", "default": "md" },
		"maxWidth": { "type": "string", "default": "default" }
	},
	"supports": {
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": [ "top", "bottom" ],
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:../style-section.css",
	"editorStyle": "file:../section.css"
}
